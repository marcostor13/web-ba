---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Bathrooms | BA Kitchen & Bath Remodeling">
  <Header />
  <main>
    <!-- Hero Section -->
    <section 
      class="relative h-[100dvh] flex items-end justify-between px-6 md:px-[54px] lg:px-[140px] pb-16 md:pb-24 bg-cover bg-center" 
      style="background-image: url('/bathroom/Image_Header (7).png');"
    >
      <div class="absolute inset-0 bg-black/10"></div>
      <div class="relative z-10 w-full flex flex-col md:flex-row justify-between items-end gap-8">
        <h1 class="text-6xl md:text-[100px] leading-[0.9] font-light text-white m-0 reveal reveal-left">
          Bathroom<br /><span class="ml-0">Projects</span>
        </h1>
        <div class="hidden md:block reveal reveal-right">
          <span class="text-[12px] uppercase tracking-[0.4em] text-white/60 font-medium">Projects</span>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="bg-beige-light px-6 md:px-[54px] lg:px-[140px] py-[110px]">
      <div class="max-w-[1200px] mx-auto">
        <div id="loader" class="flex justify-center py-10 w-full hidden">
          <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gold"></div>
        </div>

        <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-24">
          <!-- Dynamic content -->
        </div>

        <div id="empty-state" class="py-32 text-center hidden reveal reveal-up">
          <p class="text-[14px] uppercase tracking-widest text-black-soft/40 italic">Coming Soon</p>
        </div>
      </div>
    </section>

    <script is:inline>
      const grid = document.getElementById('projects-grid');
      const loader = document.getElementById('loader');
      const emptyState = document.getElementById('empty-state');

      async function fetchProjects() {
        if(loader) loader.classList.remove('hidden');
        try {
          const res = await fetch('/api/projects.php?action=list&category=Bathroom');
          const json = await res.json();
          if (json.success && json.data) {
            const projects = json.data;
            if (projects.length === 0) {
              if(emptyState) emptyState.classList.remove('hidden');
            } else {
              grid.innerHTML = projects.map((project, index) => `
                <div class="flex flex-col gap-8 reveal reveal-up" style="animation-delay: ${index * 100}ms">
                  <a href="/projects/bathroom/detail?id=${project.id}" class="group relative aspect-square overflow-hidden block">
                    <img 
                      src="${project.main_image}" 
                      alt="${project.name}" 
                      class="w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-110" 
                    />
                    <div class="absolute inset-0 bg-black/40 transition-opacity duration-500"></div>
                    ${project.logo_overlay ? `
                      <div class="absolute inset-0 flex items-center justify-center p-12">
                        <img 
                          src="${project.logo_overlay}" 
                          alt="Project Logo" 
                          class="w-[140px] h-[80px] object-contain brightness-0 invert opacity-100 group-hover:scale-110 transition-transform duration-700" 
                        />
                      </div>
                    ` : ''}
                    <div class="absolute inset-0 border border-gold opacity-0 group-hover:opacity-100 transition-opacity duration-500 m-4"></div>
                  </a>
                  <div class="text-center flex flex-col gap-2">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-gold font-bold">Bathroom</span>
                    <h3 class="text-[18px] md:text-[22px] uppercase tracking-[0.2em] font-light text-black-soft/80">
                      ${project.name}
                    </h3>
                  </div>
                </div>
              `).join('');

              setTimeout(() => {
                grid.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
              }, 50);
            }
          }
        } catch(e) { console.error(e); }
        if(loader) loader.classList.add('hidden');
      }

      window.addEventListener('load', fetchProjects);
    </script>
  </main>
</Layout>
