---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Manage Blog">
  <div class="flex flex-col gap-10">
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div class="flex flex-col gap-2">
        <h1 class="text-[12px] uppercase tracking-[0.4em] text-black-soft/40 font-medium">Content / Blog</h1>
        <h2 class="text-4xl md:text-[50px] font-light text-black-soft m-0 uppercase tracking-tight">Blog Posts</h2>
      </div>
      <a href="/admin/blog/create" class="bg-gold text-white px-8 py-3 uppercase tracking-[0.2em] text-[10px] font-medium hover:bg-black-soft transition-colors shadow-lg flex items-center gap-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Create Post
      </a>
    </header>

    <div id="loader" class="flex justify-center py-10 w-full hidden">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gold"></div>
    </div>

    <div id="table-container" class="bg-white border border-black-soft/5 rounded-sm overflow-hidden hidden">
      <table class="w-full text-left border-collapse">
          <thead>
              <tr class="border-b border-black-soft/10 bg-beige-light/20">
                  <th class="p-4 text-[10px] uppercase tracking-[0.2em] text-black-soft/60 font-medium w-[80px]">Image</th>
                  <th class="p-4 text-[10px] uppercase tracking-[0.2em] text-black-soft/60 font-medium">Title</th>
                  <th class="p-4 text-[10px] uppercase tracking-[0.2em] text-black-soft/60 font-medium w-[150px]">Date</th>
                  <th class="p-4 text-[10px] uppercase tracking-[0.2em] text-black-soft/60 font-medium w-[120px] text-right">Actions</th>
              </tr>
          </thead>
          <tbody id="posts-tbody">
              <!-- Rendered by JS -->
          </tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    async function loadPosts() {
      const loader = document.getElementById('loader');
      const tableContainer = document.getElementById('table-container');
      const tbody = document.getElementById('posts-tbody');

      loader.classList.remove('hidden');
      tableContainer.classList.add('hidden');
      tbody.innerHTML = '';

      try {
        const res = await fetch('/api/blog.php?action=list');
        const json = await res.json();
        
        if (json.success && json.data) {
          const posts = json.data;
          
          if (posts.length === 0) {
            tbody.innerHTML = `
              <tr>
                <td colspan="4" class="p-10 text-center text-black-soft/40 font-light italic text-sm">
                  No posts found. Start by creating one.
                </td>
              </tr>
            `;
          } else {
            tbody.innerHTML = posts.map(post => `
              <tr class="border-b border-black-soft/5 hover:bg-beige-light/10 transition-colors group">
                  <td class="p-4">
                      <img src="${post.main_image}" alt="${post.title}" class="w-12 h-12 object-cover rounded-sm bg-gray-100" />
                  </td>
                  <td class="p-4">
                      <div class="flex flex-col gap-1">
                          <span class="text-sm font-light text-black-soft group-hover:text-gold transition-colors">${post.title}</span>
                          <span class="text-xs text-black-soft/40 font-light truncate max-w-[300px]">${post.short_description || ''}</span>
                      </div>
                  </td>
                  <td class="p-4">
                      <span class="text-xs text-black-soft/60 font-light font-mono">
                          ${new Date(post.created_at).toLocaleDateString()}
                      </span>
                  </td>
                  <td class="p-4 text-right">
                      <div class="flex justify-end gap-3 items-center">
                          <a href="/admin/blog/edit?id=${post.id}" class="text-[10px] uppercase tracking-widest text-black-soft hover:text-gold transition-colors font-medium border-b border-black-soft/20 hover:border-gold">Edit</a>
                          <button type="button" onclick="deletePost(${post.id})" class="text-[10px] uppercase tracking-widest text-red-500/60 hover:text-red-500 transition-colors font-medium border-b border-red-500/20 hover:border-red-500">Delete</button>
                      </div>
                  </td>
              </tr>
            `).join('');
          }
          tableContainer.classList.remove('hidden');
        }
      } catch (e) {
        console.error(e);
      } finally {
        loader.classList.add('hidden');
      }
    }

    async function deletePost(id) {
      if (!confirm('Are you sure you want to delete this post?')) return;
      
      try {
        const res = await fetch('/api/blog.php?action=delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const json = await res.json();
        
        if (json.success) {
          loadPosts();
        } else {
          if (json.error === "Unauthorized") window.location.href = '/admin/login';
          else alert('Failed to delete: ' + json.error);
        }
      } catch(e) {
        alert('An error occurred during deletion.');
      }
    }

    window.addEventListener('load', loadPosts);
  </script>
</AdminLayout>
