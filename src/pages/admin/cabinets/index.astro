---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Manage Cabinets">
  <div class="flex flex-col gap-10">
    <header class="flex flex-col md:flex-row justify-between items-end gap-6">
      <div class="flex flex-col gap-2">
        <h1 class="text-[12px] uppercase tracking-[0.4em] text-black-soft/40 font-medium">Inventory</h1>
        <h2 class="text-4xl md:text-[50px] font-light text-black-soft m-0">Colors Cabinets</h2>
      </div>
      <a 
        href="/admin/cabinets/create" 
        class="bg-gold text-white px-8 py-4 uppercase tracking-[0.3em] text-[11px] font-medium hover:bg-black-soft transition-colors flex items-center gap-3"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Cabinet
      </a>
    </header>

    <div id="loader" class="flex justify-center py-10 w-full hidden">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gold"></div>
    </div>

    <div id="table-container" class="bg-white shadow-xl rounded-sm border border-black-soft/5 overflow-hidden hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black-soft/5">
              <th class="px-8 py-6 text-[10px] uppercase tracking-[0.2em] font-medium text-black-soft/60">Image</th>
              <th class="px-8 py-6 text-[10px] uppercase tracking-[0.2em] font-medium text-black-soft/60">Details</th>
              <th class="px-8 py-6 text-[10px] uppercase tracking-[0.2em] font-medium text-black-soft/60">Tag</th>
              <th class="px-8 py-6 text-[10px] uppercase tracking-[0.2em] font-medium text-black-soft/60">Actions</th>
            </tr>
          </thead>
          <tbody id="cabinets-tbody" class="divide-y divide-black-soft/5 font-light">
            <!-- Rows injected here -->
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script is:inline>
    async function loadCabinets() {
      const loader = document.getElementById('loader');
      const tableContainer = document.getElementById('table-container');
      const tbody = document.getElementById('cabinets-tbody');

      loader.classList.remove('hidden');
      tableContainer.classList.add('hidden');
      tbody.innerHTML = '';

      try {
        const res = await fetch('/api/cabinets.php?action=list');
        const json = await res.json();
        
        if (json.success && json.data) {
          const cabinets = json.data;
          
          if (cabinets.length === 0) {
            tbody.innerHTML = `
              <tr>
                <td colspan="4" class="px-8 py-20 text-center text-black-soft/30 italic font-light tracking-widest text-sm">
                  No cabinets found. Start by adding your first product.
                </td>
              </tr>
            `;
          } else {
            tbody.innerHTML = cabinets.map(item => `
              <tr class="hover:bg-beige-light/30 transition-colors">
                <td class="px-8 py-6">
                  <div class="w-20 h-24 bg-beige-light flex items-center justify-center overflow-hidden rounded-sm">
                    <img src="${item.image || ''}" alt="${item.name}" class="w-full h-full object-contain" />
                  </div>
                </td>
                <td class="px-8 py-6">
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase tracking-widest text-gold font-medium">${item.brand}</span>
                    <span class="text-lg text-black-soft">${item.name}</span>
                    <span class="text-xs text-black-soft/40">${item.series || ''}</span>
                  </div>
                </td>
                <td class="px-8 py-6">
                  <span class="px-3 py-1 bg-black-soft/5 rounded-full text-[10px] uppercase tracking-widest text-black-soft/60">
                    ${item.tag || 'White'}
                  </span>
                </td>
                <td class="px-8 py-6">
                  <div class="flex items-center gap-4">
                    <a href="/admin/cabinets/edit?id=${item.id}" class="text-[10px] uppercase tracking-widest text-black-soft hover:text-gold transition-colors font-medium border-b border-black-soft/20 hover:border-gold">Edit</a>
                    <button 
                      type="button"
                      onclick="deleteCabinet(${item.id})"
                      class="text-[10px] uppercase tracking-widest text-red-500/60 hover:text-red-500 transition-colors font-medium border-b border-red-500/20 hover:border-red-500"
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            `).join('');
          }
          tableContainer.classList.remove('hidden');
        }
      } catch (e) {
        console.error(e);
      } finally {
        loader.classList.add('hidden');
      }
    }

    async function deleteCabinet(id) {
      if (!confirm('Are you sure you want to delete this product?')) return;
      
      try {
        const res = await fetch('/api/cabinets.php?action=delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const json = await res.json();
        
        if (json.success) {
          loadCabinets();
        } else {
          if (json.error === "Unauthorized") window.location.href = '/admin/login';
          else alert('Failed to delete: ' + json.error);
        }
      } catch(e) {
        alert('An error occurred during deletion.');
      }
    }

    window.addEventListener('load', loadCabinets);
  </script>
</AdminLayout>
