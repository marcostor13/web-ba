---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Manage Projects">
  <div class="flex flex-col gap-10">
    <header class="flex flex-col md:flex-row justify-between items-end gap-6">
      <div class="flex flex-col gap-2">
        <h1 class="text-[12px] uppercase tracking-[0.4em] text-black-soft/40 font-medium">Portfolio</h1>
        <h2 class="text-4xl md:text-[50px] font-light text-black-soft m-0">Projects</h2>
      </div>
      <a 
        href="/admin/projects/create" 
        class="bg-gold text-white px-8 py-4 uppercase tracking-[0.3em] text-[11px] font-medium hover:bg-black-soft transition-colors flex items-center gap-3"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Project
      </a>
    </header>

    <div id="loader" class="flex justify-center py-10 w-full hidden">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gold"></div>
    </div>

    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Projects rendered here -->
    </div>
    
    <div id="empty-state" class="hidden py-20 text-center border-2 border-dashed border-black-soft/5 rounded-sm">
      <p class="text-black-soft/40 font-light italic">No projects added yet.</p>
    </div>
  </div>

  <script is:inline>
    async function loadProjects() {
      const loader = document.getElementById('loader');
      const grid = document.getElementById('projects-grid');
      const emptyState = document.getElementById('empty-state');

      loader.classList.remove('hidden');
      grid.innerHTML = '';
      emptyState.classList.add('hidden');

      try {
        const res = await fetch('/api/projects.php?action=list');
        const json = await res.json();
        if (json.success && json.data) {
          const projects = json.data;
          if (projects.length === 0) {
            emptyState.classList.remove('hidden');
          } else {
            grid.innerHTML = projects.map(project => `
              <div class="bg-white shadow-xl rounded-sm border border-black-soft/5 overflow-hidden group">
                <div class="relative aspect-video overflow-hidden bg-beige-light">
                  <img 
                    src="${project.main_image}" 
                    alt="${project.name}" 
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  />
                  ${project.logo_overlay ? `
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center p-12">
                      <img src="${project.logo_overlay}" alt="Logo Overlay" class="max-w-full max-h-full object-contain brightness-0 invert" />
                    </div>
                  ` : ''}
                </div>
                <div class="p-6 flex flex-col gap-4">
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase tracking-widest text-gold font-medium">${project.category}</span>
                    <h3 class="text-lg text-black-soft font-normal">${project.name}</h3>
                  </div>
                  <div class="flex items-center justify-between pt-4 border-t border-black-soft/5">
                    <div class="flex gap-4">
                      <a href="/admin/projects/edit?id=${project.id}" class="text-[10px] uppercase tracking-widest text-black-soft hover:text-gold transition-colors font-medium">Edit</a>
                      <button type="button" onclick="deleteProject(${project.id})" class="text-[10px] uppercase tracking-widest text-red-500/60 hover:text-red-500 transition-colors font-medium">Delete</button>
                    </div>
                  </div>
                </div>
              </div>
            `).join('');
          }
        }
      } catch (e) {
        console.error(e);
      } finally {
        loader.classList.add('hidden');
      }
    }

    async function deleteProject(id) {
      if (!confirm('Silently delete this project? This cannot be undone.')) return;
      
      try {
        const res = await fetch('/api/projects.php?action=delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const json = await res.json();
        
        if (json.success) {
          // Re-auth logic or just reload list if session still valid
          loadProjects();
        } else {
          if (json.error === "Unauthorized") {
            window.location.href = '/admin/login';
          } else {
            alert('Failed to delete: ' + json.error);
          }
        }
      } catch(e) {
        console.error(e);
        alert('An error occurred during deletion.');
      }
    }

    window.addEventListener('load', loadProjects);
  </script>
</AdminLayout>
