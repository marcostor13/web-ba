---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Blog | BA Kitchen & Bath Remodeling">
  <Header />
  <main>
    <!-- Hero Section -->
    <section 
      class="relative h-[100dvh] min-h-[100dvh] flex items-end justify-start text-white px-6 md:px-[54px] pt-[110px] pb-10 md:pb-[100px] bg-cover bg-center" 
      style="background-image: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), url('/blog/image_header_6.webp');"
    >
      <div class="reveal reveal-up">
        <h1 class="text-5xl md:text-[80px] leading-tight font-light text-white m-0">
          Blog
        </h1>
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="bg-beige-light px-6 md:px-[54px] lg:px-[140px] py-[110px] min-h-[100dvh]">
      <div id="loader" class="flex justify-center py-10 w-full hidden">
        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gold"></div>
      </div>

       <div id="blog-grid" class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24">
          <!-- Articles render here -->
       </div>

       <div id="empty-state" class="py-32 text-center hidden reveal reveal-up">
          <p class="text-[14px] uppercase tracking-widest text-black-soft/40 italic">Coming Soon</p>
        </div>
    </section>

    <script is:inline>
      const grid = document.getElementById('blog-grid');
      const loader = document.getElementById('loader');
      const emptyState = document.getElementById('empty-state');

      async function fetchPosts() {
        if(loader) loader.classList.remove('hidden');
        try {
          const res = await fetch('/api/blog.php?action=list');
          const json = await res.json();
          if (json.success && json.data) {
            const posts = json.data;
            if (posts.length === 0) {
              if(emptyState) emptyState.classList.remove('hidden');
            } else {
              grid.innerHTML = posts.map((post, index) => `
                 <article class="flex flex-col gap-6 reveal reveal-up delay-${(index % 2) * 200}">
                    <a href="/blog/article?slug=${post.slug}" class="block overflow-hidden group">
                        <img 
                          src="${post.main_image}" 
                          alt="${post.title}" 
                          class="w-full aspect-[4/3] object-cover transition-transform duration-700 group-hover:scale-105" 
                        />
                    </a>
                    <div class="flex flex-col gap-4">
                        <h2 class="text-[24px] md:text-[28px] font-light text-black-soft leading-tight">
                            <a href="/blog/article?slug=${post.slug}" class="hover:text-gold transition-colors">${post.title}</a>
                        </h2>
                        <p class="text-[15px] leading-relaxed text-black-soft/70 font-light line-clamp-3">
                            ${post.short_description || ''}
                        </p>
                        <a href="/blog/article?slug=${post.slug}" class="text-[12px] uppercase tracking-[0.2em] text-gold hover:text-black-soft transition-colors w-fit border-b border-gold pb-1 mt-2">
                            Read more
                        </a>
                    </div>
                 </article>
              `).join('');

              setTimeout(() => {
                grid.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
              }, 50);
            }
          }
        } catch(e) { console.error(e); }
        if(loader) loader.classList.add('hidden');
      }

      window.addEventListener('load', fetchPosts);
    </script>
  </main>
</Layout>
