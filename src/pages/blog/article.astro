---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Article | Blog">
  <Header />
  <main class="bg-[#F3EBE3]">
    <div id="loader" class="fixed inset-0 z-50 flex items-center justify-center bg-white">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-gold"></div>
    </div>

    <div id="article-content" class="hidden">
       <!-- Hero Image (No Overlay) -->
       <section id="hero-section" class="w-full h-[60vh] md:h-[80vh] bg-cover bg-center" style="background-image: url('');">
       </section>

       <!-- Title & Intro Section -->
       <section class="max-w-4xl mx-auto px-6 pt-16 pb-8 text-center flex flex-col items-center gap-6">
          <div class="reveal reveal-up">
              <span class="text-[12px] md:text-[14px] uppercase tracking-[0.2em] text-black-soft/60 font-light">
                  <span id="post-category">Blog</span> | DESIGN SPOTLIGHT
              </span>
              <h1 id="post-title" class="text-4xl md:text-[60px] lg:text-[72px] text-black-soft font-light leading-tight mt-6 mb-8">
              </h1>
              <p id="post-desc" class="text-[16px] md:text-[18px] text-black-soft/80 font-light leading-relaxed max-w-3xl mx-auto italic">
              </p>
          </div>
       </section>

       <!-- Content Sections -->
       <article id="sections-container" class="max-w-[900px] mx-auto px-6 pb-24 flex flex-col gap-12">
          <!-- Sections inserted here -->
       </article>
        
       <!-- Related Posts -->
       <section class="bg-white/30 py-24 px-6 md:px-[54px] lg:px-[140px] border-t border-black/5">
          <div class="max-w-[1200px] mx-auto">
              <h3 class="text-xl font-light text-black-soft mb-12 uppercase tracking-widest text-center">Related Posts</h3>
              <div id="related-grid" class="grid grid-cols-1 md:grid-cols-3 gap-10">
                  <!-- Related posts here -->
              </div>
          </div>
       </section>
    </div>

    <script is:inline>
      async function init() {
        const params = new URLSearchParams(window.location.search);
        const slug = params.get('slug');
        
        if (!slug) {
          window.location.href = '/blog';
          return;
        }

        try {
          // 1. Fetch Post and Sections
          const res = await fetch(`/api/blog.php?action=get&slug=${slug}`);
          const json = await res.json();
          
          if (!json.success || !json.data) {
            window.location.href = '/blog';
            return;
          }

          const post = json.data;
          const sections = json.sections || [];
          
          document.title = `${post.title} | Blog`;
          
          // Populate Hero & Intro
          if (post.main_image) {
              document.getElementById('hero-section').style.backgroundImage = `url('${post.main_image}')`;
          }
          document.getElementById('post-title').innerText = post.title;
          document.getElementById('post-desc').innerText = post.short_description || '';
          document.getElementById('post-category').innerText = post.category || 'Blog';

          // Populate Sections
          const sectionsHtml = sections.map((section, index) => {
            let innerHtml = '';
            if (section.type === 'title') {
                innerHtml = `<h2 class="text-2xl md:text-[32px] font-light text-black-soft mb-6 text-center leading-tight">${section.content_text || ''}</h2>`;
            } else if (section.type === 'paragraph') {
                innerHtml = `<p class="text-[16px] md:text-[18px] text-black-soft/90 font-light leading-[1.7] whitespace-pre-line tracking-normal text-center max-w-2xl mx-auto">${section.content_text || ''}</p>`;
            } else if (section.type === 'image_single') {
                if (section.image_path_1) {
                    innerHtml = `<div class="my-6"><img src="${section.image_path_1}" alt="${post.title}" class="w-full h-auto object-cover rounded-sm shadow-sm" /></div>`;
                }
            } else if (section.type === 'image_double') {
                let imgs = '';
                if (section.image_path_1) imgs += `<img src="${section.image_path_1}" alt="Gallery 1" class="w-full h-[300px] md:h-[500px] object-cover rounded-sm shadow-sm" />`;
                if (section.image_path_2) imgs += `<img src="${section.image_path_2}" alt="Gallery 2" class="w-full h-[300px] md:h-[500px] object-cover rounded-sm shadow-sm" />`;
                if (imgs) {
                    innerHtml = `<div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-6">${imgs}</div>`;
                }
            }
            return innerHtml ? `<div class="reveal reveal-up delay-${(index % 3) * 100} w-full">${innerHtml}</div>` : '';
          }).join('');
          
          document.getElementById('sections-container').innerHTML = sectionsHtml;

          // Enable view and animations
          document.getElementById('loader').style.display = 'none';
          document.getElementById('article-content').classList.remove('hidden');

          setTimeout(() => {
            document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
          }, 100);

          // 2. Fetch Related (lazy load)
          loadRelated(post.id);

        } catch (e) {
          console.error(e);
          window.location.href = '/blog';
        }
      }

      async function loadRelated(currentId) {
        try {
          const res = await fetch('/api/blog.php?action=list');
          const json = await res.json();
          if (json.success && json.data) {
            const related = json.data.filter(p => p.id != currentId).slice(0, 3);
            const gridHtml = related.map(p => `
              <a href="/blog/article?slug=${p.slug}" class="group flex flex-col gap-4 reveal reveal-up">
                <div class="overflow-hidden aspect-[4/3] bg-black-soft/5">
                    ${p.main_image ? `<img src="${p.main_image}" alt="${p.title}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />` : ''}
                </div>
                <h4 class="text-lg font-light text-black-soft group-hover:text-gold transition-colors text-center">${p.title}</h4>
              </a>
            `).join('');
            document.getElementById('related-grid').innerHTML = gridHtml;

            setTimeout(() => {
              document.getElementById('related-grid').querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
            }, 100);
          }
        } catch(e) {}
      }

      window.addEventListener('load', init);
    </script>
  </main>
</Layout>
